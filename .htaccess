Options -Indexes
DirectoryIndex index.html index.php

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Forzar HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Bloquear archivos ocultos, excepto .well-known
  RewriteRule (^|/)\.(?!well-known(?:/|$)) - [F,L]

  # Bloquear archivos sensibles
  RewriteRule (^|/)(?:\.env(?:\..*)?|composer\.json|composer\.lock)$ - [F,L,NC]
  RewriteRule \.(?:log|bak|backup|old|sql|zip|rar|tar|gz|7z)$ - [F,L,NC]

  # Bloquear carpetas internas o no publicas
  RewriteRule ^(?:docs|storage|vendor|sistema/tools|sistema/config|config)(?:/|$) - [F,L,NC]

  # Bloqueo temporal del sistema interno
  RewriteRule ^sistema(?:/|$) - [F,L,NC]
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
</IfModule>

<FilesMatch "^(?:\.env(?:\..*)?|composer\.json|composer\.lock)$">
  Require all denied
</FilesMatch>

<FilesMatch "\.(?:log|bak|backup|old|sql|zip|rar|tar|gz|7z)$">
  Require all denied
</FilesMatch>

# HSTS se debe habilitar solo cuando HTTPS esté activo y estable en produccion.
# Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"


