Options -Indexes
DirectoryIndex index.html index.php

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteRule (^|/)\.(?!well-known(?:/|$)) - [F,L]
  RewriteRule (^|/)(?:\.env(?:\..*)?|composer\.json|composer\.lock)$ - [F,L,NC]
  RewriteRule \.(?:log|bak|backup|old|sql|zip|rar|tar|gz)$ - [F,L,NC]
  RewriteRule ^(?:docs|storage|vendor|sistema/tools|sistema/config|config)(?:/|$) - [F,L,NC]
</IfModule>

<FilesMatch "^(?:\.env(?:\..*)?|composer\.json|composer\.lock)$">
  Require all denied
</FilesMatch>

<FilesMatch "\.(?:log|bak|backup|old|sql|zip|rar|tar|gz)$">
  Require all denied
</FilesMatch>

# HSTS se debe habilitar solo cuando HTTPS esté activo y estable en producción.
# Ejemplo (mantener comentado hasta validar):
# Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
